{
    "name": "wind111-lang/sumire",
    "description": "A small PDO Mapper for PHP 8.2+.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "Sumire\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sumire\\Tests\\": "tests/",
            "Sumire\\Tests\\Fixtures\\": "tests/Fixtures/"
        }
    },
    "scripts": {
        "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
        "test": [
            "@composer dump-autoload --dev --quiet",
            "vendor/bin/phpunit"
        ],
        "test:integration": [
            "@composer dump-autoload --dev --quiet",
            "php tests/integration.php"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "cs:check": "vendor/bin/php-cs-fixer check --diff --verbose --using-cache=no --allow-unsupported-php-version=yes",
        "cs:fix": "vendor/bin/php-cs-fixer fix --diff --verbose --using-cache=no --allow-unsupported-php-version=yes",
        "ci": [
            "@lint",
            "@test",
            "@analyse",
            "@cs:check"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75"
    }
}
